{
  "version": 1,
  "description": "Dev-complete UI branch checklist for Lift Logger. Every required id must have a scene in export-all-scenes.mjs.",
  "outOfScope": [
    "Tweaks panel UI (design-time only, hidden in export)",
    "Transient LOG flash animation",
    "Per-accent-color on every screen (accents covered on logger only)",
    "Every scroll pixel on split grid (top + scrolled is enough)",
    "Duplicate barbell exercises beyond representative squat/bench/dead/ohp"
  ],
  "branches": [
    { "id": "nav-start", "ui": "Start screen", "requiredScene": "start-native", "alsoCoveredBy": ["start-mono", "start-athletic"] },
    { "id": "nav-splits-grid", "ui": "Split picker grid", "requiredScene": "splits-grid", "alsoCoveredBy": ["splits-mono", "splits-athletic", "splits-scrolled"] },
    { "id": "nav-splits-scroll", "ui": "Split grid scrolled", "requiredScene": "splits-scrolled" },
    { "id": "sheet-fullbody", "ui": "Full Body day sheet", "requiredScene": "splits-fullbody-days" },
    { "id": "sheet-upperlower", "ui": "Upper/Lower day sheet", "requiredScene": "splits-upperlower-days" },
    { "id": "sheet-ppl", "ui": "PPL day sheet", "requiredScene": "splits-ppl-days" },
    { "id": "sheet-bro", "ui": "Bro split day sheet", "requiredScene": "splits-bro-days" },
    { "id": "sheet-plus-menu", "ui": "Start without a split menu", "requiredScene": "splits-plus-menu" },
    { "id": "splits-custom-card", "ui": "User custom split card in grid", "requiredScene": "splits-with-custom-card" },
    { "id": "idle-logged", "ui": "Session idle with logged sets", "requiredScene": "idle-with-sets" },
    { "id": "idle-nothing-logged", "ui": "Session idle, plan exists, no sets yet", "requiredScene": "idle-nothing-logged-yet" },
    { "id": "idle-empty-plan", "ui": "Empty plan / ADD EXERCISE", "requiredScene": "idle-empty-plan" },
    { "id": "idle-save-mode", "ui": "Save-mode draft split", "requiredScene": "idle-save-mode" },
    { "id": "logger-barbell", "ui": "Logger · barbell wheel", "requiredScene": "logger-bench-barbell", "alsoCoveredBy": ["logger-squat-barbell", "logger-dead-barbell", "logger-ohp-barbell"] },
    { "id": "logger-dumbbell", "ui": "Logger · dumbbell rack", "requiredScene": "logger-curl-dumbbell" },
    { "id": "logger-pin-stack", "ui": "Logger · machine pin stack", "requiredScene": "logger-row-pin-stack", "alsoCoveredBy": ["logger-lat-pin-stack"] },
    { "id": "logger-machine-wheel", "ui": "Logger · machine weight wheel", "requiredScene": "logger-row-wheel", "alsoCoveredBy": ["logger-lat-wheel"] },
    { "id": "logger-coarse-fine", "ui": "Logger · coarse + fine wheels", "requiredScene": "logger-coarse-fine" },
    { "id": "logger-uniform", "ui": "Logger · uniform mechanism", "requiredScene": "logger-uniform" },
    { "id": "logger-touch-test", "ui": "Logger · touch test overlay", "requiredScene": "logger-touch-test" },
    { "id": "logger-edit-plan", "ui": "Edit exercises wiggle mode", "requiredScene": "logger-edit-exercises" },
    { "id": "logger-closed", "ui": "Logger sheet dismissed", "requiredScene": "logger-sheet-closed" },
    { "id": "new-exercise-barbell", "ui": "New exercise · barbell", "requiredScene": "new-exercise-barbell" },
    { "id": "new-exercise-dumbbell", "ui": "New exercise · dumbbell", "requiredScene": "new-exercise-dumbbell" },
    { "id": "new-exercise-machine", "ui": "New exercise · machine plates", "requiredScene": "new-exercise-machine" },
    { "id": "new-exercise-empty", "ui": "New exercise · disabled submit", "requiredScene": "new-exercise-empty-name" },
    { "id": "library-anatomy", "ui": "Library · muscle selected (chest)", "requiredScene": "library-anatomy-default" },
    { "id": "library-tap-muscle", "ui": "Library · no muscle selected", "requiredScene": "library-tap-muscle" },
    { "id": "library-muscle-filter", "ui": "Library · muscle filter (lats)", "requiredScene": "library-muscle-lats" },
    { "id": "library-search-hit", "ui": "Library · search with results", "requiredScene": "library-search-bench" },
    { "id": "library-search-empty", "ui": "Library · search no results", "requiredScene": "library-search-empty" },
    { "id": "library-free-flow", "ui": "Library · quick session empty plan", "requiredScene": "library-free-flow" },
    { "id": "vibe-mono-idle", "ui": "Mono vibe · idle", "requiredScene": "idle-mono" },
    { "id": "vibe-athletic-idle", "ui": "Athletic vibe · idle", "requiredScene": "idle-athletic" },
    { "id": "vibe-mono-logger", "ui": "Mono vibe · logger", "requiredScene": "logger-mono" },
    { "id": "vibe-athletic-logger", "ui": "Athletic vibe · logger", "requiredScene": "logger-athletic-red" },
    { "id": "accent-green", "ui": "Green accent · logger", "requiredScene": "logger-accent-green" },
    { "id": "accent-orange", "ui": "Orange accent · logger", "requiredScene": "logger-accent-orange" },
    { "id": "behavior-no-pr", "ui": "PR markers off", "requiredScene": "logger-no-pr-marker" },
    { "id": "behavior-pin-absolute", "ui": "Pin drag absolute", "requiredScene": "logger-pin-absolute" },
    { "id": "behavior-auto-close", "ui": "After LOG auto-close (sheet closed, post-log state)", "requiredScene": "logger-after-log-closed" }
  ]
}
